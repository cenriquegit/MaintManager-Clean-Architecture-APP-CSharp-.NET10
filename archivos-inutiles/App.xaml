<?xml version="1.0" encoding="UTF-8"?>
<!-- MaintManager.MAUI/App.xaml — VERSIÓN FINAL -->
<!-- Registra Colors, Styles y todos los Converters como recursos globales -->
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:MaintManager.MAUI.Converters"
    x:Class="MaintManager.MAUI.App">

    <Application.Resources>
        <ResourceDictionary>

            <!-- ── Paleta y estilos ── -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Converters globales ── -->
            <conv:InvertedBoolConverter       x:Key="InvertedBoolConverter"/>
            <conv:IsNotNullConverter          x:Key="IsNotNullConverter"/>
            <conv:IsNullConverter             x:Key="IsNullConverter"/>
            <conv:IntToBoolConverter          x:Key="IntToBoolConverter"/>
            <conv:StringEqualsConverter       x:Key="StringEqualsConverter"/>
            <conv:AlertTypeToColorConverter   x:Key="AlertTypeToColorConverter"/>
            <conv:AlertTypeToLabelConverter   x:Key="AlertTypeToLabelConverter"/>
            <conv:StockStatusColorConverter   x:Key="StockStatusColorConverter"/>
            <conv:DaysUntilExpiryColorConverter x:Key="DaysUntilExpiryColorConverter"/>

            <!-- BoolToColorConverter con colores NeoPlus preconfigurados -->
            <conv:BoolToColorConverter x:Key="BelowMinimumColorConverter"
                                       TrueColor="#E53935"
                                       FalseColor="#2ECC71"/>

        </ResourceDictionary>
    </Application.Resources>

</Application>

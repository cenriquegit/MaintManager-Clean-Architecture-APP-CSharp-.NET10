<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Style x:Key="BodyText" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style x:Key="CaptionText" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="#666666" />
    </Style>
    <Style x:Key="FormEntry" TargetType="Entry">
        <Setter Property="FontSize" Value="16" />
    </Style>
    <Style x:Key="FormPicker" TargetType="Picker">
        <Setter Property="FontSize" Value="16" />
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ColorPrimary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#EEEEEE" />
        <Setter Property="TextColor" Value="#333333" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Shadow" Value="{StaticResource DefaultShadow}" />
    </Style>
    <!-- Sombra simple (si no existe, se ignora) -->
    <Shadow x:Key="DefaultShadow"
            Brush="#33000000"
            Offset="0,2"
            Radius="4"
            Opacity="0.2" />
    <Style x:Key="TitleMedium" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource ColorAccentDark}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Color x:Key="ColorBorderLight">#E0E0E0</Color>

    <Style x:Key="BadgeError" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource ColorErrorContainer}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 99" />
        <Setter Property="Padding" Value="8,2" />
    </Style>
</ResourceDictionary>
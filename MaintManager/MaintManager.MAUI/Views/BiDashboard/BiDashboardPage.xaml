<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.BiDashboard"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
    x:Class="MaintManager.MAUI.Views.BiDashboard.BiDashboardPage"
    Title="Dashboard"
    BackgroundColor="{StaticResource ColorBackground}">

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsLoading}">
        <Grid>

            <!-- LOADING -->
            <VerticalStackLayout IsVisible="{Binding IsLoading}"
                                 HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="True" Color="{StaticResource ColorPrimary}"/>
                <Label Text="Cargando dashboard..." Style="{StaticResource BodyText}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- ERROR -->
            <VerticalStackLayout IsVisible="{Binding HasError}"
                                 HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                <Label Text="⚠" FontSize="40" HorizontalOptions="Center"
                       TextColor="{StaticResource ColorError}"/>
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyText}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                <Button Text="Reintentar" Command="{Binding LoadCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- EMPTY -->
            <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                 HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                <Label Text="📊" FontSize="48" HorizontalOptions="Center"/>
                <Label Text="No hay datos disponibles." Style="{StaticResource BodyText}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- SUCCESS -->
            <ScrollView IsVisible="{Binding IsSuccess}">
                <VerticalStackLayout Spacing="16" Padding="16,8,16,24">

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- KPI Cards Row -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🚗" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="{Binding TotalVehicles}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorPrimary}" HorizontalOptions="Center"/>
                                <Label Text="Vehículos" FontSize="11" TextColor="{StaticResource ColorTextSecondary}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="8">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🔧" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="{Binding ServicesThisMonth}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorSuccess}" HorizontalOptions="Center"/>
                                <Label Text="Servicios" FontSize="11" TextColor="{StaticResource ColorTextSecondary}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="8">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="📦" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="{Binding LowStockMaterials}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorWarning}" HorizontalOptions="Center"/>
                                <Label Text="Stock Bajo" FontSize="11" TextColor="{StaticResource ColorTextSecondary}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource Card}" Padding="8">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="⚠" FontSize="20" HorizontalOptions="Center"/>
                                <Label Text="{Binding UnresolvedAlerts}" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorError}" HorizontalOptions="Center"/>
                                <Label Text="Alertas" FontSize="11" TextColor="{StaticResource ColorTextSecondary}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- Secondary KPI Row: Fleet Avg Cost + Emergency Rate -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Border Style="{StaticResource Card}" Padding="12">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="Costo Promedio por Km"
                                       FontSize="13" TextColor="{StaticResource ColorTextSecondary}"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding FleetAvgCostPerKm}" FontSize="22" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorPrimary}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="12">
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="Tasa de Emergencia"
                                       FontSize="13" TextColor="{StaticResource ColorTextSecondary}"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding EmergencyRatePercent}" FontSize="22" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorWarning}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- Chart 1: Costo por Km -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Border Style="{StaticResource Card}" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Costo por Kilómetro por Vehículo"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Text="Top 10 vehículos con mayor costo operativo por km"
                                   FontSize="12" TextColor="{StaticResource ColorTextSecondary}"/>
                            <lvc:CartesianChart
                                Series="{Binding CostPerKmSeries}"
                                XAxes="{Binding CostPerKmXAxes}"
                                YAxes="{Binding CostPerKmYAxes}"
                                HeightRequest="220"
                                ZoomMode="None"
                                TooltipPosition="Top"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- Chart 2: Tasa de Emergencia -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Border Style="{StaticResource Card}" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Tasa de Emergencia por Vehículo"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Text="Porcentaje de servicios de emergencia sobre el total"
                                   FontSize="12" TextColor="{StaticResource ColorTextSecondary}"/>
                            <lvc:CartesianChart
                                Series="{Binding EmergencyRateSeries}"
                                XAxes="{Binding EmergencyRateXAxes}"
                                YAxes="{Binding EmergencyRateYAxes}"
                                HeightRequest="200"
                                ZoomMode="None"
                                TooltipPosition="Top"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- Chart 3: Costos Mensuales -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Border Style="{StaticResource Card}" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Evolución de Costos Mensuales"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Text="Últimos 6 meses"
                                   FontSize="12" TextColor="{StaticResource ColorTextSecondary}"/>
                            <lvc:CartesianChart
                                Series="{Binding MonthlyCostSeries}"
                                XAxes="{Binding MonthlyCostXAxes}"
                                YAxes="{Binding MonthlyCostYAxes}"
                                HeightRequest="220"
                                ZoomMode="None"
                                TooltipPosition="Top"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- Chart 4: Lotes Próximos a Vencer -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Border Style="{StaticResource Card}" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Lotes Próximos a Vencer"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Text="Cantidad de material por estado de vencimiento"
                                   FontSize="12" TextColor="{StaticResource ColorTextSecondary}"/>
                            <lvc:PieChart
                                Series="{Binding ExpiringLotsSeries}"
                                HeightRequest="220"
                                TooltipPosition="Top"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═══════════════════════════════════════════ -->
                    <!-- Chart 5: Desviación de Calendario -->
                    <!-- ═══════════════════════════════════════════ -->
                    <Border Style="{StaticResource Card}" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Desviación de Mantenimiento Programado"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Text="Top 10 vehículos con mayor desviación de km respecto al cronograma"
                                   FontSize="12" TextColor="{StaticResource ColorTextSecondary}"/>
                            <lvc:CartesianChart
                                Series="{Binding ComplianceSeries}"
                                XAxes="{Binding ComplianceXAxes}"
                                YAxes="{Binding ComplianceYAxes}"
                                HeightRequest="220"
                                ZoomMode="None"
                                TooltipPosition="Top"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </RefreshView>
</ContentPage>

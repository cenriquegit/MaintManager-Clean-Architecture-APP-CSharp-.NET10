<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Auth"
             x:Class="MaintManager.MAUI.Views.Auth.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="Iniciar Sesión"
             BackgroundColor="{StaticResource ColorSurface}">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
        <Image Source="appicon.svg" HeightRequest="80" WidthRequest="80" HorizontalOptions="Center" />

        <Label Text="MaintManager" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />

        <Entry Placeholder="Usuario" Text="{Binding Username}" />
        <Entry Placeholder="Contraseña" IsPassword="True" Text="{Binding Password}" />

        <!-- Mensaje de error -->
        <Label Text="{Binding ErrorMessage}" 
               TextColor="{StaticResource ColorError}"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

        <Button Text="Ingresar" 
                Command="{Binding LoginCommand}" 
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                Style="{StaticResource PrimaryButton}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" />
    </VerticalStackLayout>
</ContentPage>
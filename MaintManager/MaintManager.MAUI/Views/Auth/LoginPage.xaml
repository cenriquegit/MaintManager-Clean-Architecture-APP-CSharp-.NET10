<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Auth"
             x:Class="MaintManager.MAUI.Views.Auth.LoginPage"
             Title="Iniciar Sesión"
             BackgroundColor="{StaticResource ColorSurface}">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
        <Image Source="icon" HeightRequest="80" WidthRequest="80" HorizontalOptions="Center" />

        <Label Text="MaintManager" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />

        <!-- Configuración URL colapsable -->
        <Border StrokeShape="RoundRectangle 8"
                Stroke="{StaticResource ColorBorderLight}"
                StrokeThickness="1" Padding="12,8">
            <VerticalStackLayout Spacing="8">
                <Button Text="▸ Cambiar URL de conexión"
                        Command="{Binding ToggleUrlConfigCommand}"
                        IsVisible="{Binding ShowUrlConfig, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource ColorPrimary}"
                        FontSize="13"
                        HorizontalOptions="Start"
                        Padding="0"/>
                <Button Text="▾ Ocultar conexión"
                        Command="{Binding ToggleUrlConfigCommand}"
                        IsVisible="{Binding ShowUrlConfig}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource ColorPrimary}"
                        FontSize="13"
                        HorizontalOptions="Start"
                        Padding="0"/>
                <VerticalStackLayout IsVisible="{Binding ShowUrlConfig}" Spacing="8">
                    <Label Text="URL del servidor" FontSize="12"
                           TextColor="{StaticResource ColorTextSecondary}"/>
                    <Entry Text="{Binding ApiUrl}"
                           Placeholder="http://192.168.1.100:5056"
                           Keyboard="Plain"
                           TextColor="{StaticResource ColorTextPrimary}"
                           PlaceholderColor="{StaticResource Gray500}"/>
                    <Button Text="Guardar URL"
                            Command="{Binding SaveUrlConfigCommand}"
                            BackgroundColor="{StaticResource ColorSecondary}"
                            TextColor="White"
                            HeightRequest="36" FontSize="13"
                            HorizontalOptions="Fill"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <Entry Placeholder="Usuario" Text="{Binding Username}"
               TextColor="{StaticResource ColorTextPrimary}"
               PlaceholderColor="{StaticResource Gray500}"/>
        <Grid ColumnDefinitions="*,48">
            <Entry Placeholder="Contraseña"
                   IsPassword="{Binding ShowPassword, Converter={StaticResource InvertedBoolConverter}}"
                   Text="{Binding Password}"
                   TextColor="{StaticResource ColorTextPrimary}"
                   PlaceholderColor="{StaticResource Gray500}"/>
            <Button Grid.Column="1"
                    Text="👁"
                    Command="{Binding TogglePasswordVisibilityCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource ColorTextSecondary}"
                    FontSize="22"
                    WidthRequest="48"
                    HeightRequest="48"
                    Padding="0"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>
        </Grid>

        <!-- Mensaje de error -->
        <Label Text="{Binding ErrorMessage}" 
               TextColor="{StaticResource ColorError}"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

        <Button Text="Ingresar" 
                Command="{Binding LoginCommand}" 
                Style="{StaticResource PrimaryButton}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" />
    </VerticalStackLayout>
</ContentPage>
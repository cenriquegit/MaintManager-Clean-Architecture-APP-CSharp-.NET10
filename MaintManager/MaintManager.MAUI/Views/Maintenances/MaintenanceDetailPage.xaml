<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Maintenances"
    x:Class="MaintManager.MAUI.Views.Maintenances.MaintenanceDetailPage"
    Title="{Binding Title}"
    BackgroundColor="{StaticResource ColorBackground}">

    <Grid RowDefinitions="*,Auto">

        <!-- LOADING -->
        <VerticalStackLayout IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
            <ActivityIndicator IsRunning="True" Color="{StaticResource ColorPrimary}"/>
            <Label Text="Cargando detalle..." Style="{StaticResource BodyText}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- ERROR -->
        <VerticalStackLayout IsVisible="{Binding HasError}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
            <Label Text="⚠" FontSize="40" HorizontalOptions="Center"
                   TextColor="{StaticResource ColorError}"/>
            <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyText}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            <Button Text="Reintentar" Command="{Binding LoadCommand}"
                    Style="{StaticResource SecondaryButton}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- SUCCESS -->
        <ScrollView IsVisible="{Binding IsSuccess}">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- Header: order number, vehicle, status -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding MaintenanceDetail.OrderNumber}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Border Grid.Row="0" Grid.Column="1"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 99"
                                Padding="10,4"
                                BackgroundColor="{StaticResource ColorInfoContainer}">
                            <Label Text="{Binding MaintenanceDetail.StatusName}"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorInfo}"/>
                        </Border>

                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                               Text="{Binding MaintenanceDetail.VehicleName, StringFormat='{0}'}"
                               FontSize="16"
                               TextColor="{StaticResource ColorTextPrimary}"
                               Margin="0,6,0,0"/>

                        <Label Grid.Row="2" Grid.ColumnSpan="2"
                               Text="{Binding MaintenanceDetail.LicensePlate, StringFormat='Placa: {0}'}"
                               Style="{StaticResource CaptionText}"/>
                    </Grid>
                </Border>

                <!-- Info section -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Información General"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              ColumnDefinitions="Auto,*"
                              RowSpacing="8" ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0" Text="Tipo:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.MaintenanceType}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Servicio:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.ServiceType}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="Fecha:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.MaintenanceDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="3" Grid.Column="0" Text="Kilometraje:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="3" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.Mileage, StringFormat='{0:N0} km'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="4" Grid.Column="0" Text="Técnico:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="4" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.AssignedToName}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                        </Grid>
                        <Button Text="Ver historial completo del vehículo"
                                Command="{Binding ViewVehicleHistoryCommand}"
                                FontSize="12" HeightRequest="34" Padding="10,0"
                                BackgroundColor="{StaticResource ColorInfoContainer}"
                                TextColor="{StaticResource ColorPrimary}"
                                HorizontalOptions="Start" Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Technician reassignment (only for active orders) -->
                <Border IsVisible="{Binding MaintenanceDetail.Status, Converter={StaticResource IsNotNullConverter}}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Reasignar Técnico"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="4,0">
                            <Picker ItemsSource="{Binding Technicians}"
                                    SelectedItem="{Binding SelectedTechnician}"
                                    ItemDisplayBinding="{Binding .}"
                                    Title="Seleccionar técnico..."
                                    Style="{StaticResource FormPicker}"/>
                        </Border>

                        <Button Text="Asignar"
                                Command="{Binding AssignTechnicianCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Oil info section (collapsible) -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleOilInfoCommand}"/>
                            </Grid.GestureRecognizers>
                            <Label Text="Información de Aceite"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Grid.Column="1" Text="▲" FontSize="14"
                                   TextColor="{StaticResource ColorInfo}"
                                   IsVisible="{Binding IsOilInfoExpanded}"/>
                            <Label Grid.Column="1" Text="▼" FontSize="14"
                                   TextColor="{StaticResource ColorInfo}"
                                   IsVisible="{Binding IsOilInfoExpanded, Converter={StaticResource InvertedBoolConverter}}"/>
                        </Grid>

                        <VerticalStackLayout IsVisible="{Binding IsOilInfoExpanded}" Spacing="8">
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>
                            <Label Text="{Binding MaintenanceDetail.OilBrand, StringFormat='Marca: {0}'}"
                                   TextColor="{StaticResource ColorTextPrimary}"
                                   IsVisible="{Binding MaintenanceDetail.OilBrand, Converter={StaticResource IsNotNullConverter}}"/>
                            <Label Text="{Binding MaintenanceDetail.OilViscositySae, StringFormat='Viscosidad: {0}'}"
                                   TextColor="{StaticResource ColorTextPrimary}"
                                   IsVisible="{Binding MaintenanceDetail.OilViscositySae, Converter={StaticResource IsNotNullConverter}}"/>
                            <Label Text="{Binding MaintenanceDetail.ShowOilInNextMaintenance, StringFormat='Mostrar en próximo mantenimiento: {0}'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Actions checklist -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Acciones Realizadas"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <CollectionView ItemsSource="{Binding ActionDetails}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6">
                                        <CheckBox IsChecked="{Binding IsCompleted}"
                                                  IsEnabled="False"
                                                  Color="{StaticResource ColorPrimary}"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="8,0,0,0">
                                            <Label Text="{Binding Name}"
                                                   FontSize="14"
                                                   TextColor="{StaticResource ColorTextPrimary}"/>
                                            <Label Text="{Binding Description}"
                                                   Style="{StaticResource CaptionText}"
                                                   LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2"
                                                Text="Completar"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceDetailViewModel}}, Path=CompleteActionCommand}"
                                                CommandParameter="{Binding .}"
                                                IsVisible="{Binding IsCompleted, Converter={StaticResource InvertedBoolConverter}}"
                                                Style="{StaticResource AccentButton}"
                                                FontSize="11" HeightRequest="30" Padding="8,0"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Installed Components section -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Componentes Instalados"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <CollectionView ItemsSource="{Binding Components}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 8"
                                            Stroke="{StaticResource ColorBorderLight}"
                                            StrokeThickness="1" Padding="10,6" Margin="0,2"
                                            BackgroundColor="{StaticResource ColorSurface}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="✓"
                                                   FontSize="14" TextColor="{StaticResource ColorSuccess}"
                                                   VerticalOptions="Center"/>
                                            <VerticalStackLayout Grid.Column="1" Spacing="1"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding ComponentName}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="{StaticResource ColorTextPrimary}"/>
                                                <Label Text="{Binding InstallationKm, StringFormat='Instalado en {0:N0} km'}"
                                                       Style="{StaticResource CaptionText}"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2"
                                                   Text="{Binding ExpirationDate, StringFormat='{0:dd/MM/yyyy}'}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource ColorTextSecondary}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="Sin componentes registrados en esta orden."
                                       Style="{StaticResource CaptionText}" Margin="0,8"/>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Instalar Componente -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Instalar Componente"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Label Text="Componente:" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="4,0">
                            <Picker ItemsSource="{Binding ComponentActions}"
                                    SelectedItem="{Binding SelectedComponent}"
                                    ItemDisplayBinding="{Binding .}"
                                    Title="Seleccionar componente..."
                                    Style="{StaticResource FormPicker}"/>
                        </Border>

                        <Button Text="Instalar"
                                Command="{Binding InstallComponentCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Material consumption section -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Consumir Material (FIFO)"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Label Text="Material:" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="4,0">
                            <Picker ItemsSource="{Binding AvailableMaterials}"
                                    SelectedItem="{Binding SelectedMaterial}"
                                    ItemDisplayBinding="{Binding .}"
                                    Title="Seleccionar material..."
                                    Style="{StaticResource FormPicker}"/>
                        </Border>

                        <!-- FIFO Lot info (se muestra al seleccionar un material) -->
                        <Border IsVisible="{Binding ShowLotInfo}"
                                StrokeShape="RoundRectangle 8"
                                BackgroundColor="{StaticResource ColorInfoContainer}"
                                StrokeThickness="0" Padding="12,8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Lote a consumir (FIFO):"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorTextPrimary}"/>
                                <HorizontalStackLayout Spacing="16">
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="Lote" Style="{StaticResource CaptionText}"/>
                                        <Label Text="{Binding LotNumberDisplay}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{StaticResource ColorTextPrimary}"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="Vence" Style="{StaticResource CaptionText}"/>
                                        <Label Text="{Binding LotExpiryDisplay}"
                                               FontSize="13"
                                               TextColor="{StaticResource ColorTextPrimary}"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="Costo unit." Style="{StaticResource CaptionText}"/>
                                        <Label Text="{Binding LotCostDisplay}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{StaticResource ColorPrimary}"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Label Text="Cantidad:" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="12,0">
                            <Entry Text="{Binding ConsumeQuantity}"
                                   Keyboard="Numeric"
                                   Placeholder="ej: 4.5"
                                   TextColor="{StaticResource ColorTextPrimary}"
                                   PlaceholderColor="{StaticResource Gray500}"/>
                        </Border>

                        <Button Text="Consumir"
                                Command="{Binding ConsumeMaterialCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Diagnosis section (display when exists) -->
                <Border IsVisible="{Binding Diagnosis, Converter={StaticResource IsNotNullConverter}}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Diagnóstico"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Label Text="Código:" Style="{StaticResource CaptionText}"/>
                        <Label Text="{Binding Diagnosis.Code}"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Label Text="Descripción:" Style="{StaticResource CaptionText}"/>
                        <Label Text="{Binding Diagnosis.Description}"
                               TextColor="{StaticResource ColorTextPrimary}"
                               LineBreakMode="WordWrap"/>

                        <Label Text="Acción recomendada:" Style="{StaticResource CaptionText}"/>
                        <Label Text="{Binding Diagnosis.RecommendedAction}"
                               TextColor="{StaticResource ColorTextPrimary}"
                               LineBreakMode="WordWrap"/>

                        <Label Text="Severidad:" Style="{StaticResource CaptionText}"/>
                        <Label Text="{Binding Diagnosis.Severity}"
                               TextColor="{StaticResource ColorTextPrimary}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Diagnosis form (when not yet saved) -->
                <Border IsVisible="{Binding DiagnosisSaved, Converter={StaticResource InvertedBoolConverter}}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Registrar Diagnóstico"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Label Text="Observaciones del mecánico:" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="12,4">
                            <Editor Text="{Binding DiagnosisObservations}"
                                    HeightRequest="100"
                                    Placeholder="Describe el estado del vehículo, problemas encontrados, etc."
                                    TextColor="{StaticResource ColorTextPrimary}"
                                    PlaceholderColor="{StaticResource Gray500}"/>
                        </Border>

                        <Button Text="Guardar Diagnóstico"
                                Command="{Binding SaveDiagnosisCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom actions -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="16,8,16,16">

            <Button Grid.Column="0"
                    Text="📄 Exportar PDF"
                    Command="{Binding ExportPdfCommand}"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="12"
                    HorizontalOptions="Fill"/>

            <Button Grid.Column="1"
                    Text="Cerrar Orden"
                    Command="{Binding CloseOrderCommand}"
                    IsVisible="{Binding CanClose}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalOptions="Fill"/>

        </Grid>
    </Grid>
</ContentPage>

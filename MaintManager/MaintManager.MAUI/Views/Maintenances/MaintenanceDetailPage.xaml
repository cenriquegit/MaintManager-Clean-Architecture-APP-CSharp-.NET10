<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Maintenances"
    x:Class="MaintManager.MAUI.Views.Maintenances.MaintenanceDetailPage"
    Title="{Binding Title}"
    BackgroundColor="{StaticResource ColorBackground}">

    <Grid RowDefinitions="*,Auto">

        <!-- LOADING -->
        <VerticalStackLayout IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
            <ActivityIndicator IsRunning="True" Color="{StaticResource ColorPrimary}"/>
            <Label Text="Cargando detalle..." Style="{StaticResource BodyText}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- ERROR -->
        <VerticalStackLayout IsVisible="{Binding HasError}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
            <Label Text="⚠" FontSize="40" HorizontalOptions="Center"
                   TextColor="{StaticResource ColorError}"/>
            <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyText}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            <Button Text="Reintentar" Command="{Binding LoadCommand}"
                    Style="{StaticResource SecondaryButton}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- SUCCESS -->
        <ScrollView IsVisible="{Binding IsSuccess}">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- Header: order number, vehicle, plate, status -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="2">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding MaintenanceDetail.OrderNumber}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Border Grid.Row="0" Grid.Column="1"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 99"
                                Padding="10,4"
                                BackgroundColor="{StaticResource ColorInfoContainer}">
                            <Label Text="{Binding MaintenanceDetail.StatusName}"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorInfo}"/>
                        </Border>

                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                               Text="{Binding MaintenanceDetail.VehicleName}"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Label Grid.Row="2" Grid.ColumnSpan="2"
                               Text="{Binding MaintenanceDetail.LicensePlate, StringFormat='Placa: {0}'}"
                               FontSize="14"
                               TextColor="{StaticResource ColorTextSecondary}"/>

                        <!-- Oil info inline in header -->
                        <Label Grid.Row="3" Grid.ColumnSpan="2"
                               FontSize="12" Margin="0,4,0,0"
                               TextColor="{StaticResource ColorTextSecondary}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Aceite: "/>
                                    <Span Text="{Binding MaintenanceDetail.OilBrand}"/>
                                    <Span Text=" — "/>
                                    <Span Text="{Binding MaintenanceDetail.OilViscositySae}"/>
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding MaintenanceDetail.OilBrand}"
                                             Value="{x:Null}">
                                    <Setter Property="Text" Value="No hay información de aceite"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Info General -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Información General"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnDefinitions="Auto,*"
                              RowSpacing="8" ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0" Text="Tipo:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.MaintenanceType}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Servicio:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.ServiceType}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="Fecha:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.MaintenanceDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="3" Grid.Column="0" Text="Kilometraje:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="3" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.Mileage, StringFormat='{0:N0} km'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="4" Grid.Column="0" Text="Técnico:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="4" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.AssignedToName}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <Label Grid.Row="5" Grid.Column="0" Text="Origen:" Style="{StaticResource CaptionText}"/>
                            <Label Grid.Row="5" Grid.Column="1"
                                   Text="{Binding MaintenanceDetail.OriginService}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                        </Grid>

                        <Button Text="Ver historial completo del vehículo"
                                Command="{Binding ViewVehicleHistoryCommand}"
                                FontSize="12" HeightRequest="34" Padding="10,0"
                                BackgroundColor="{StaticResource ColorInfoContainer}"
                                TextColor="{StaticResource ColorPrimary}"
                                HorizontalOptions="Start" Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Acciones Realizadas: Picker + add button + list -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Acciones Realizadas"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <!-- Input: visible solo en orden activa -->
                        <HorizontalStackLayout Spacing="6"
                                               IsVisible="{Binding IsReadOnly, Converter={StaticResource InvertedBoolConverter}}">
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource ColorBorder}"
                                    StrokeThickness="1" Padding="4,0"
                                    HorizontalOptions="FillAndExpand">
                                <Picker ItemsSource="{Binding ActionCatalogItems}"
                                        SelectedItem="{Binding SelectedActionCatalog}"
                                        ItemDisplayBinding="{Binding .}"
                                        Title="Seleccionar acción..."
                                        Style="{StaticResource FormPicker}"/>
                            </Border>
                            <Button Text="+"
                                    Command="{Binding AddActionCommand}"
                                    Style="{StaticResource AccentButton}"
                                    FontSize="20" FontAttributes="Bold"
                                    HeightRequest="44" WidthRequest="44"
                                    CornerRadius="22" Padding="0"/>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <CollectionView ItemsSource="{Binding ActionDetails}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ActionDetailItem">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,4">
                                        <CheckBox IsChecked="{Binding IsCompleted}"
                                                  IsEnabled="False"
                                                  Color="{StaticResource ColorPrimary}"
                                                  IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceDetailViewModel}}, Path=IsReadOnly, Converter={StaticResource InvertedBoolConverter}}"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="1" Margin="8,0,0,0">
                                            <Label Text="{Binding Name}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource ColorTextPrimary}"/>
                                            <Label Text="{Binding Description}"
                                                   Style="{StaticResource CaptionText}"
                                                   LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2"
                                                Text="✕"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceDetailViewModel}}, Path=RemoveActionCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource ColorErrorContainer}"
                                                TextColor="{StaticResource ColorError}"
                                                FontSize="12" FontAttributes="Bold"
                                                HeightRequest="30" WidthRequest="30"
                                                CornerRadius="15" Padding="0"
                                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceDetailViewModel}}, Path=IsReadOnly, Converter={StaticResource InvertedBoolConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text=" No hay acciones registradas. Agrega una desde el selector."
                                       Style="{StaticResource CaptionText}" Margin="0,8"/>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Consumir Material: picker + quantity + list -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Consumir Material (FIFO)"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <!-- Input: visible solo en orden activa -->
                        <VerticalStackLayout Spacing="8"
                                             IsVisible="{Binding IsReadOnly, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="Material:" Style="{StaticResource CaptionText}"/>
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource ColorBorder}"
                                    StrokeThickness="1" Padding="4,0">
                                <Picker ItemsSource="{Binding AvailableMaterials}"
                                        SelectedItem="{Binding SelectedMaterial}"
                                        ItemDisplayBinding="{Binding .}"
                                        Title="Seleccionar material..."
                                        Style="{StaticResource FormPicker}"/>
                            </Border>

                            <!-- FIFO Lot info -->
                            <Border IsVisible="{Binding ShowLotInfo}"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource ColorInfoContainer}"
                                    StrokeThickness="0" Padding="12,8">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Lote a consumir (FIFO):"
                                           FontSize="12" FontAttributes="Bold"
                                           TextColor="{StaticResource ColorTextPrimary}"/>
                                    <HorizontalStackLayout Spacing="16">
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="Lote" Style="{StaticResource CaptionText}"/>
                                            <Label Text="{Binding LotNumberDisplay}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="{StaticResource ColorTextPrimary}"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="Vence" Style="{StaticResource CaptionText}"/>
                                            <Label Text="{Binding LotExpiryDisplay}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource ColorTextPrimary}"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="Costo unit." Style="{StaticResource CaptionText}"/>
                                            <Label Text="{Binding LotCostDisplay}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="{StaticResource ColorPrimary}"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                            <HorizontalStackLayout Spacing="6">
                                <VerticalStackLayout HorizontalOptions="FillAndExpand">
                                    <Label Text="Cantidad:" Style="{StaticResource CaptionText}"/>
                                    <Border StrokeShape="RoundRectangle 8"
                                            Stroke="{StaticResource ColorBorder}"
                                            StrokeThickness="1" Padding="12,0"
                                            HeightRequest="44">
                                        <Entry Text="{Binding ConsumeQuantity}"
                                               Keyboard="Numeric"
                                               Placeholder="ej: 4.5"
                                               TextColor="{StaticResource ColorTextPrimary}"
                                               PlaceholderColor="{StaticResource Gray500}"/>
                                    </Border>
                                </VerticalStackLayout>
                                <Button Text="Consumir"
                                        Command="{Binding ConsumeMaterialCommand}"
                                        Style="{StaticResource AccentButton}"
                                        HeightRequest="44" WidthRequest="80"
                                        VerticalOptions="End"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <CollectionView ItemsSource="{Binding ConsumedMaterials}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ConsumedMaterialItem">
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                        <VerticalStackLayout Spacing="1">
                                            <Label Text="{Binding MaterialName}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource ColorTextPrimary}"/>
                                            <Label FontSize="12"
                                                   TextColor="{StaticResource ColorTextSecondary}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding LotNumber, StringFormat='Lote: {0}'}"/>
                                                        <Span Text=" — "/>
                                                        <Span Text="{Binding UnitCost, StringFormat='S/ {0:N2}'}"/>
                                                        <Span Text=" × "/>
                                                        <Span Text="{Binding Quantity}"/>
                                                        <Span Text=" = "/>
                                                        <Span Text="{Binding TotalCost, StringFormat='S/ {0:N2}'}" FontAttributes="Bold"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label Text="{Binding Rating, StringFormat='Calificación: {0} ⭐'}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource ColorPrimary}"
                                                   IsVisible="{Binding Rating, Converter={StaticResource IntToBoolConverter}}"/>
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1"
                                                Text="✕"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceDetailViewModel}}, Path=RemoveConsumedMaterialCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource ColorErrorContainer}"
                                                TextColor="{StaticResource ColorError}"
                                                FontSize="12" FontAttributes="Bold"
                                                HeightRequest="30" WidthRequest="30"
                                                CornerRadius="15" Padding="0"
                                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceDetailViewModel}}, Path=IsReadOnly, Converter={StaticResource InvertedBoolConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text=" No hay materiales consumidos en esta orden."
                                       Style="{StaticResource CaptionText}" Margin="0,8"/>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Instalar Componente: picker + install + list -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Componentes Instalados"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <!-- Input: visible solo en orden activa -->
                        <HorizontalStackLayout Spacing="6"
                                               IsVisible="{Binding IsReadOnly, Converter={StaticResource InvertedBoolConverter}}">
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource ColorBorder}"
                                    StrokeThickness="1" Padding="4,0"
                                    HorizontalOptions="FillAndExpand">
                                <Picker ItemsSource="{Binding ComponentActions}"
                                        SelectedItem="{Binding SelectedComponent}"
                                        ItemDisplayBinding="{Binding .}"
                                        Title="Seleccionar componente..."
                                        Style="{StaticResource FormPicker}"/>
                            </Border>
                            <Button Text="+"
                                    Command="{Binding InstallComponentCommand}"
                                    Style="{StaticResource AccentButton}"
                                    FontSize="20" FontAttributes="Bold"
                                    HeightRequest="44" WidthRequest="44"
                                    CornerRadius="22" Padding="0"/>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <CollectionView ItemsSource="{Binding Components}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ComponentItem">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                                        <Label Grid.Column="0" Text="✓"
                                               FontSize="14" TextColor="{StaticResource ColorSuccess}"
                                               VerticalOptions="Center"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="1">
                                            <Label Text="{Binding ComponentName}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="{StaticResource ColorTextPrimary}"/>
                                            <Label Text="{Binding InstallationKm, StringFormat='Instalado en {0:N0} km'}"
                                                   Style="{StaticResource CaptionText}"/>
                                            <Label Text="{Binding ExpirationDate, StringFormat='Vence: {0:dd/MM/yyyy}'}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource ColorTextSecondary}"
                                                   IsVisible="{Binding ExpirationDate, Converter={StaticResource IsNotNullConverter}}"/>
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2"
                                                Text="✕"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceDetailViewModel}}, Path=RemoveComponentLocalCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource ColorErrorContainer}"
                                                TextColor="{StaticResource ColorError}"
                                                FontSize="12" FontAttributes="Bold"
                                                HeightRequest="30" WidthRequest="30"
                                                CornerRadius="15" Padding="0"
                                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceDetailViewModel}}, Path=IsReadOnly, Converter={StaticResource InvertedBoolConverter}}"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text=" Sin componentes instalados en esta orden."
                                       Style="{StaticResource CaptionText}" Margin="0,8"/>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Reasignar Técnico (solo en orden activa) -->
                <Border IsVisible="{Binding IsReadOnly, Converter={StaticResource InvertedBoolConverter}}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8"
                                         IsEnabled="{Binding IsReadOnly, Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="Reasignar Técnico"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="4,0">
                            <Picker ItemsSource="{Binding Technicians}"
                                    SelectedItem="{Binding SelectedTechnician}"
                                    ItemDisplayBinding="{Binding .}"
                                    Title="Seleccionar técnico..."
                                    Style="{StaticResource FormPicker}"/>
                        </Border>

                        <Button Text="Asignar"
                                Command="{Binding AssignTechnicianCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Diagnóstico (display when exists) -->
                <Border IsVisible="{Binding Diagnosis, Converter={StaticResource IsNotNullConverter}}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Diagnóstico"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Label Text="{Binding Diagnosis.GeneralStatus, StringFormat='Estado general: {0}'}"
                               TextColor="{StaticResource ColorTextPrimary}"/>
                        <Label Text="{Binding Diagnosis.VehicleOperative, StringFormat='Vehículo operativo: {0}'}"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Label Text="Observaciones:" Style="{StaticResource CaptionText}"
                               IsVisible="{Binding Diagnosis.Observations, Converter={StaticResource IsNotNullConverter}}"/>
                        <Label Text="{Binding Diagnosis.Observations}"
                               TextColor="{StaticResource ColorTextPrimary}"
                               LineBreakMode="WordWrap"
                               IsVisible="{Binding Diagnosis.Observations, Converter={StaticResource IsNotNullConverter}}"/>

                        <Label Text="Recomendaciones futuras:" Style="{StaticResource CaptionText}"
                               IsVisible="{Binding Diagnosis.FutureRecommendations, Converter={StaticResource IsNotNullConverter}}"/>
                        <Label Text="{Binding Diagnosis.FutureRecommendations}"
                               TextColor="{StaticResource ColorTextPrimary}"
                               LineBreakMode="WordWrap"
                               IsVisible="{Binding Diagnosis.FutureRecommendations, Converter={StaticResource IsNotNullConverter}}"/>

                        <Label Text="{Binding Diagnosis.CreatedAt, StringFormat='Diagnosticado el: {0:dd/MM/yyyy HH:mm}'}"
                               Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Diagnosis form (when not yet saved and not read-only) -->
                <Border IsVisible="{Binding DiagnosisSaved, Converter={StaticResource InvertedBoolConverter}}"
                        IsEnabled="{Binding IsReadOnly, Converter={StaticResource InvertedBoolConverter}}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="16"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Registrar Diagnóstico"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Label Text="Estado general del vehículo:" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="4,0">
                            <Picker ItemsSource="{Binding GeneralStatusOptions}"
                                    SelectedItem="{Binding SelectedGeneralStatus}"
                                    Title="Seleccionar estado..."
                                    Style="{StaticResource FormPicker}"/>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                            <Label Text="Vehículo operativo:" VerticalOptions="Center"
                                   Style="{StaticResource CaptionText}"/>
                            <Switch Grid.Column="1" IsToggled="{Binding IsVehicleOperative}"
                                    OnColor="{StaticResource ColorSuccess}"
                                    ThumbColor="{StaticResource ColorPrimary}"/>
                        </Grid>

                        <Label Text="Observaciones del mecánico:" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="12,4">
                            <Editor Text="{Binding DiagnosisObservations}"
                                    HeightRequest="100"
                                    Placeholder="Describe el estado del vehículo, problemas encontrados, etc."
                                    TextColor="{StaticResource ColorTextPrimary}"
                                    PlaceholderColor="{StaticResource Gray500}"/>
                        </Border>

                        <Label Text="Recomendaciones para próximos servicios:" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="12,4">
                            <Editor Text="{Binding FutureRecommendations}"
                                    HeightRequest="80"
                                    Placeholder="Ej: Revisar correa de distribución en 10000 km"
                                    TextColor="{StaticResource ColorTextPrimary}"
                                    PlaceholderColor="{StaticResource Gray500}"/>
                        </Border>

                        <Button Text="Guardar Diagnóstico"
                                Command="{Binding SaveDiagnosisCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom actions -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="16,8,16,16">

            <Button Grid.Column="0"
                    Text=" Exportar PDF"
                    Command="{Binding ExportPdfCommand}"
                    IsVisible="{Binding IsReadOnly}"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="12"
                    HorizontalOptions="Fill"/>

            <Button Grid.Column="1"
                    Text="Cerrar Orden"
                    Command="{Binding CloseOrderCommand}"
                    IsVisible="{Binding CanClose}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalOptions="Fill"/>

        </Grid>
    </Grid>
</ContentPage>

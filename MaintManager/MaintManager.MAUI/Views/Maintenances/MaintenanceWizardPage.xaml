<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Maintenances"
    x:Class="MaintManager.MAUI.Views.Maintenances.MaintenanceWizardPage"
    Title="{Binding Title}"
    BackgroundColor="{StaticResource ColorBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Step indicator -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource ColorSurface}" StrokeThickness="0" Padding="16,10">
            <HorizontalStackLayout Spacing="6">
                <Label Text="Paso" FontSize="13" TextColor="{StaticResource ColorTextSecondary}" VerticalOptions="Center"/>
                <Label Text="{Binding CurrentStep, StringFormat='{0}/4'}" FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource ColorPrimary}" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <!-- Content area -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Step 1: Vehicle selection + mileage -->
                <VerticalStackLayout IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"
                                     Spacing="16">
                    <Label Text="Seleccionar Vehículo" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource ColorTextPrimary}"/>
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource ColorBorder}"
                            StrokeThickness="1" Padding="4,0">
                        <Picker ItemsSource="{Binding Vehicles}"
                                SelectedItem="{Binding SelectedVehicle}"
                                ItemDisplayBinding="{Binding .}"
                                Title="Seleccionar vehículo..."
                                Style="{StaticResource FormPicker}"/>
                    </Border>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Kilometraje actual (km)" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="12,0">
                            <Entry Text="{Binding MileageText}"
                                   Keyboard="Numeric"
                                   Placeholder="ej: 45000"
                                   TextColor="{StaticResource ColorTextPrimary}"
                                   PlaceholderColor="{StaticResource Gray500}"/>
                        </Border>
                        <Label Text="{Binding MileageWarning}"
                               IsVisible="{Binding ShowMileageWarning}"
                               FontSize="12" TextColor="{StaticResource ColorError}"
                               Margin="0,4,0,0" LineBreakMode="WordWrap"/>
                        <Label Text="{Binding VehicleLastKm, StringFormat='Último km registrado: {0} km'}"
                               IsVisible="{Binding SelectedVehicle, Converter={StaticResource IsNotNullConverter}}"
                               FontSize="12" TextColor="{StaticResource ColorTextSecondary}"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Step 2: Service type selection -->
                <VerticalStackLayout IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}"
                                     Spacing="16">
                    <Label Text="Tipo de Servicio" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource ColorTextPrimary}"/>
                    <Label Text="Selecciona el tipo de servicio a realizar:"
                           Style="{StaticResource BodyText}"/>

                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource ColorBorder}"
                            StrokeThickness="1" Padding="4,0">
                        <Picker ItemsSource="{Binding ServiceTypes}"
                                SelectedItem="{Binding SelectedServiceType}"
                                Title="Seleccionar tipo de servicio..."
                                Style="{StaticResource FormPicker}"/>
                    </Border>

                    <Label Text="{Binding ServiceTypeDescription}"
                           IsVisible="{Binding SelectedServiceType, Converter={StaticResource IsNotNullConverter}}"
                           FontSize="12"
                           TextColor="{StaticResource ColorTextSecondary}"
                           LineBreakMode="WordWrap"
                           Margin="0,-8,0,0"/>
                </VerticalStackLayout>

                <!-- Step 3: Technician assignment -->
                <VerticalStackLayout IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3}"
                                     Spacing="16">
                    <Label Text="Asignar Técnico" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource ColorTextPrimary}"/>
                    <Label Text="Selecciona el mecánico responsable de esta orden:"
                           Style="{StaticResource BodyText}"/>

                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource ColorBorder}"
                            StrokeThickness="1" Padding="4,0">
                        <Picker ItemsSource="{Binding Technicians}"
                                SelectedItem="{Binding SelectedTechnician}"
                                ItemDisplayBinding="{Binding .}"
                                Title="Seleccionar técnico..."
                                Style="{StaticResource FormPicker}"/>
                    </Border>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nota para el mecánico (opcional):" Style="{StaticResource CaptionText}"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource ColorBorder}"
                                StrokeThickness="1" Padding="12,4">
                            <Editor Text="{Binding MechanicNote}"
                                    Placeholder="ej: Revisar también el aire acondicionado..."
                                    HeightRequest="100"
                                    TextColor="{StaticResource ColorTextPrimary}"
                                    PlaceholderColor="{StaticResource Gray500}"/>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Step 4: Confirmation -->
                <VerticalStackLayout IsVisible="{Binding CurrentStep, Converter={StaticResource IntToBoolConverter}, ConverterParameter=4}"
                                     Spacing="16">
                    <Label Text="Confirmar y Guardar" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource ColorTextPrimary}"/>
                    <Label Text="Revisa los datos antes de guardar:"
                           Style="{StaticResource BodyText}"/>

                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource ColorBorderLight}"
                            StrokeThickness="1" Padding="16"
                            BackgroundColor="{StaticResource ColorSurface}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Resumen de la Orden" FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                            <Label Text="{Binding SelectedVehicle, StringFormat='Vehículo: {0}'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Text="{Binding MileageText, StringFormat='Kilometraje: {0} km'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Text="{Binding SelectedServiceType, StringFormat='Servicio: {0}'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>
                            <Label Text="{Binding SelectedTechnician, StringFormat='Técnico: {0}'}"
                                   TextColor="{StaticResource ColorTextPrimary}"/>

                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                            <Label Text="Los materiales, operaciones y diagnóstico se registrarán en la página de detalle después de crear la orden."
                                   Style="{StaticResource CaptionText}" LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border IsVisible="{Binding HasError}"
                            BackgroundColor="{StaticResource ColorErrorContainer}"
                            StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,8">
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{StaticResource ColorError}" FontSize="13"/>
                    </Border>

                    <ActivityIndicator IsRunning="{Binding IsSaving}"
                                       IsVisible="{Binding IsSaving}"
                                       HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Navigation buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12" Padding="16,8,16,16">
            <Button Grid.Column="0"
                    Text="Anterior"
                    Command="{Binding PreviousStepCommand}"
                    IsVisible="{Binding IsFirstStep, Converter={StaticResource InvertedBoolConverter}}"
                    Style="{StaticResource SecondaryButton}"/>

            <Button Grid.Column="1"
                    Text="Siguiente"
                    Command="{Binding NextStepCommand}"
                    IsVisible="{Binding IsNextButtonVisible}"
                    Style="{StaticResource PrimaryButton}"/>

            <Button Grid.Column="1"
                    Text="Guardar"
                    Command="{Binding SaveCommand}"
                    IsVisible="{Binding IsSaveButtonVisible}"
                    Style="{StaticResource PrimaryButton}"/>
        </Grid>

    </Grid>
</ContentPage>

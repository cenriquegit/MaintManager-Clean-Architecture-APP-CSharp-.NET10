<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MaintManager.MAUI.Views.VehicleConfig.VehicleConfigPage"
    Title="Config. Vehículos"
    BackgroundColor="{StaticResource ColorBackground}">

    <Grid>
        <VerticalStackLayout IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
            <ActivityIndicator IsRunning="True" Color="{StaticResource ColorPrimary}"/>
            <Label Text="Cargando..." Style="{StaticResource BodyText}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <VerticalStackLayout IsVisible="{Binding HasError}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
            <Label Text="⚠" FontSize="40" HorizontalOptions="Center" TextColor="{StaticResource ColorError}"/>
            <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyText}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            <Button Text="Reintentar" Command="{Binding LoadVehiclesCommand}"
                    Style="{StaticResource SecondaryButton}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <ScrollView IsVisible="{Binding IsSuccess}">
            <VerticalStackLayout Padding="16" Spacing="16">

                <Button Text="← Volver a Vehículos" Command="{Binding BackToVehiclesCommand}"
                        Style="{StaticResource SecondaryButton}" FontSize="13"
                        HorizontalOptions="Start" Margin="0,0,0,0"/>

                <Label Text="⚙ Configuración por Vehículo"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"/>
                <Label Text="Selecciona un vehículo para configurar sus acciones, materiales y componentes permitidos."
                       Style="{StaticResource BodyText}" LineBreakMode="WordWrap"/>

                <Border StrokeShape="RoundRectangle 8"
                        Stroke="{StaticResource ColorBorder}"
                        StrokeThickness="1" Padding="4,0">
                    <Picker ItemsSource="{Binding Vehicles}"
                            SelectedItem="{Binding SelectedVehicle}"
                            ItemDisplayBinding="{Binding .}"
                            Title="Seleccionar vehículo..."
                            Style="{StaticResource FormPicker}"/>
                </Border>

                <!-- ACTIONS CARD -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="12"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📋 Acciones Permitidas" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource ColorBorder}"
                                    StrokeThickness="1" Padding="4,0">
                                <Picker ItemsSource="{Binding AvailableActions}"
                                        SelectedItem="{Binding SelectedAction}"
                                        ItemDisplayBinding="{Binding .}"
                                        Title="Seleccionar acción..."
                                        Style="{StaticResource FormPicker}"/>
                            </Border>
                            <Button Grid.Column="1" Text="+"
                                    Command="{Binding AddActionCommand}"
                                    Style="{StaticResource AccentButton}"
                                    FontSize="18" FontAttributes="Bold"
                                    HeightRequest="40" WidthRequest="40"
                                    CornerRadius="20" Padding="0"/>
                        </Grid>

                        <Button Text="➕ Nueva Acción..." Command="{Binding CreateActionCommand}"
                                Style="{StaticResource SecondaryButton}" FontSize="13"
                                HorizontalOptions="Start"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <CollectionView ItemsSource="{Binding AllowedActions}" HeightRequest="160">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,4">
                                        <Label Text="✓" FontSize="14" TextColor="{StaticResource ColorSuccess}"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding Name}" FontSize="14"
                                               TextColor="{StaticResource ColorTextPrimary}"
                                               Margin="8,0,0,0" VerticalOptions="Center"/>
                                        <Border Grid.Column="2" StrokeShape="RoundRectangle 14"
                                                StrokeThickness="0" HeightRequest="28" WidthRequest="28"
                                                BackgroundColor="{StaticResource ColorErrorContainer}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnRemoveActionTapped"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="✕" FontSize="11" TextColor="{StaticResource ColorError}"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="Sin acciones configuradas." Style="{StaticResource CaptionText}" Margin="0,8"/>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- MATERIALS CARD -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="12"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🛢 Materiales Permitidos" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource ColorBorder}"
                                    StrokeThickness="1" Padding="4,0">
                                <Picker ItemsSource="{Binding AvailableMaterials}"
                                        SelectedItem="{Binding SelectedMaterial}"
                                        ItemDisplayBinding="{Binding .}"
                                        Title="Seleccionar material..."
                                        Style="{StaticResource FormPicker}"/>
                            </Border>
                            <Button Grid.Column="1" Text="+"
                                    Command="{Binding AddMaterialCommand}"
                                    Style="{StaticResource AccentButton}"
                                    FontSize="18" FontAttributes="Bold"
                                    HeightRequest="40" WidthRequest="40"
                                    CornerRadius="20" Padding="0"/>
                        </Grid>

                        <Button Text="➕ Nuevo Material..." Command="{Binding CreateMaterialCommand}"
                                Style="{StaticResource SecondaryButton}" FontSize="13"
                                HorizontalOptions="Start"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <CollectionView ItemsSource="{Binding AllowedMaterials}" HeightRequest="160">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,4">
                                        <Label Text="✓" FontSize="14" TextColor="{StaticResource ColorSuccess}"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding Name}" FontSize="14"
                                               TextColor="{StaticResource ColorTextPrimary}"
                                               Margin="8,0,0,0" VerticalOptions="Center"/>
                                        <Border Grid.Column="2" StrokeShape="RoundRectangle 14"
                                                StrokeThickness="0" HeightRequest="28" WidthRequest="28"
                                                BackgroundColor="{StaticResource ColorErrorContainer}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnRemoveMaterialTapped"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="✕" FontSize="11" TextColor="{StaticResource ColorError}"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="Sin materiales configurados." Style="{StaticResource CaptionText}" Margin="0,8"/>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- COMPONENTS CARD -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1" Padding="12"
                        BackgroundColor="{StaticResource ColorSurface}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🔩 Componentes Permitidos" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}"/>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource ColorBorder}"
                                    StrokeThickness="1" Padding="4,0">
                                <Picker ItemsSource="{Binding AvailableComponents}"
                                        SelectedItem="{Binding SelectedComponent}"
                                        ItemDisplayBinding="{Binding .}"
                                        Title="Seleccionar componente..."
                                        Style="{StaticResource FormPicker}"/>
                            </Border>
                            <Button Grid.Column="1" Text="+"
                                    Command="{Binding AddComponentCommand}"
                                    Style="{StaticResource AccentButton}"
                                    FontSize="18" FontAttributes="Bold"
                                    HeightRequest="40" WidthRequest="40"
                                    CornerRadius="20" Padding="0"/>
                        </Grid>

                        <Button Text="➕ Nuevo Componente..." Command="{Binding CreateComponentCommand}"
                                Style="{StaticResource SecondaryButton}" FontSize="13"
                                HorizontalOptions="Start"/>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <CollectionView ItemsSource="{Binding AllowedComponents}" HeightRequest="160">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,4">
                                        <Label Text="✓" FontSize="14" TextColor="{StaticResource ColorSuccess}"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding Name}" FontSize="14"
                                               TextColor="{StaticResource ColorTextPrimary}"
                                               Margin="8,0,0,0" VerticalOptions="Center"/>
                                        <Border Grid.Column="2" StrokeShape="RoundRectangle 14"
                                                StrokeThickness="0" HeightRequest="28" WidthRequest="28"
                                                BackgroundColor="{StaticResource ColorErrorContainer}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnRemoveComponentTapped"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="✕" FontSize="11" TextColor="{StaticResource ColorError}"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="Sin componentes configurados." Style="{StaticResource CaptionText}" Margin="0,8"/>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MaintManager.MAUI.Views.Agenda.AgendaPage"
    Title="Agenda"
    BackgroundColor="{StaticResource ColorBackground}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <Border Grid.Row="0" Margin="16,8,16,0" StrokeShape="RoundRectangle 8"
                Stroke="{StaticResource ColorBorderLight}" StrokeThickness="1"
                BackgroundColor="{StaticResource ColorSurface}" Padding="4,0">
            <SearchBar Text="{Binding SearchText}"
                       Placeholder="Buscar vehículo o placa..."
                       BackgroundColor="Transparent"
                       TextColor="{StaticResource ColorTextPrimary}"
                       PlaceholderColor="{StaticResource Gray500}"
                       CancelButtonColor="{StaticResource ColorPrimary}"
                       SearchIconColor="{StaticResource ColorTextSecondary}"/>
        </Border>

        <HorizontalStackLayout Grid.Row="1" Margin="16,8" Spacing="12">
            <Label Text="Filtrar:" Style="{StaticResource CaptionText}" VerticalOptions="Center"/>
            <Picker ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilter}"
                    Title="Todas"
                    Style="{StaticResource FormPicker}" WidthRequest="160"/>
        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="2" IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" ZIndex="10">
            <ActivityIndicator IsRunning="True" Color="{StaticResource ColorPrimary}"/>
            <Label Text="Cargando agenda..." Style="{StaticResource BodyText}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="2" IsVisible="{Binding HasError}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="16" ZIndex="10">
            <Label Text="⚠" FontSize="40" HorizontalOptions="Center" TextColor="{StaticResource ColorError}"/>
            <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyText}" HorizontalOptions="Center"/>
            <Button Text="Reintentar" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="2" IsVisible="{Binding IsSuccess}">
            <VerticalStackLayout Spacing="12" Padding="16,0,16,16">

                <CollectionView ItemsSource="{Binding Overdue}">
                    <CollectionView.Header>
                        <Label Text="🔴 CRÍTICO — KM vencido" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource ColorError}" Margin="0,8,0,4"/>
                    </CollectionView.Header>
                    <CollectionView.EmptyView>
                        <Label Text="No hay vehículos con KM vencido ✓" Style="{StaticResource CaptionText}" Margin="8,4" TextColor="{StaticResource Gray500}"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" Margin="0,0,0,8" BackgroundColor="{StaticResource ColorSurface}"
                                    StrokeShape="RoundRectangle 10" Stroke="{StaticResource ColorBorderLight}" StrokeThickness="1">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnItemTapped"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Plate}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource ColorTextPrimary}"/>
                                    <Label Text="{Binding VehicleName}" FontSize="13" TextColor="{StaticResource ColorTextSecondary}"/>
                                    <Label Text="{Binding KmLine}" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                    <Label Text="{Binding StatusLabel}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource ColorError}"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView ItemsSource="{Binding Upcoming}">
                    <CollectionView.Header>
                        <Label Text="🟡 PRÓXIMO — Zona de alerta" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource ColorWarning}" Margin="0,4"/>
                    </CollectionView.Header>
                    <CollectionView.EmptyView>
                        <Label Text="No hay vehículos en zona de alerta ✓" Style="{StaticResource CaptionText}" Margin="8,4" TextColor="{StaticResource Gray500}"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" Margin="0,0,0,8" BackgroundColor="{StaticResource ColorSurface}"
                                    StrokeShape="RoundRectangle 10" Stroke="{StaticResource ColorBorderLight}" StrokeThickness="1">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnItemTapped"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Plate}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource ColorTextPrimary}"/>
                                    <Label Text="{Binding VehicleName}" FontSize="13" TextColor="{StaticResource ColorTextSecondary}"/>
                                    <Label Text="{Binding KmLine}" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                    <Label Text="{Binding StatusLabel}" FontSize="12" TextColor="{StaticResource ColorWarning}"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView ItemsSource="{Binding InService}">
                    <CollectionView.Header>
                        <Label Text="🟢 EN SERVICIO" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource ColorSuccess}" Margin="0,4"/>
                    </CollectionView.Header>
                    <CollectionView.EmptyView>
                        <Label Text="No hay vehículos en servicio actualmente" Style="{StaticResource CaptionText}" Margin="8,4" TextColor="{StaticResource Gray500}"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" Margin="0,0,0,8" BackgroundColor="{StaticResource ColorSurface}"
                                    StrokeShape="RoundRectangle 10" Stroke="{StaticResource ColorBorderLight}" StrokeThickness="1">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnItemTapped"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding Plate}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource ColorTextPrimary}"/>
                                    <Label Text="{Binding VehicleName}" FontSize="13" TextColor="{StaticResource ColorTextSecondary}"/>
                                    <Label Text="{Binding StatusLabel}" FontSize="12" TextColor="{StaticResource ColorSuccess}"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView ItemsSource="{Binding Ok}">
                    <CollectionView.Header>
                        <HorizontalStackLayout Spacing="4" Margin="0,4">
                            <Label Text="⚪ AL DÍA" FontSize="13" TextColor="{StaticResource ColorTextSecondary}" VerticalOptions="Center"/>
                            <Label Text="{Binding Ok.Count, StringFormat='({0})'}" FontSize="11" TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,4" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Plate}" FontSize="14" TextColor="{StaticResource ColorTextPrimary}" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding KmLine}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="3" BackgroundColor="#1A1A2E" StrokeThickness="0" Padding="16,10">
            <Button Text="+ Nueva orden" Command="{Binding CreateNewCommand}"
                    BackgroundColor="#1565C0" TextColor="White" FontAttributes="Bold"
                    HeightRequest="46" CornerRadius="10" HorizontalOptions="Fill"/>
        </Border>
    </Grid>
</ContentPage>

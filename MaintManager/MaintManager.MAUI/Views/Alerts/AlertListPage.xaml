<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MaintManager.MAUI.Views.Alerts.AlertListPage"
    Title="Alertas"
    BackgroundColor="{StaticResource ColorBackground}">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsRefreshing}">
        <Grid RowDefinitions="Auto,Auto,*,Auto">

            <Border Grid.Row="0" Margin="16,8,16,0" StrokeShape="RoundRectangle 8"
                    Stroke="{StaticResource ColorBorderLight}" StrokeThickness="1"
                    BackgroundColor="{StaticResource ColorSurface}" Padding="4,0">
            <SearchBar Text="{Binding SearchText}"
                        Placeholder="Buscar alerta..."
                        SearchCommand="{Binding SearchCommand}"
                        BackgroundColor="Transparent"
                           TextColor="{StaticResource ColorTextPrimary}"
                           PlaceholderColor="{StaticResource Gray500}"
                           CancelButtonColor="{StaticResource ColorPrimary}"
                           SearchIconColor="{StaticResource ColorTextSecondary}"/>
            </Border>

            <HorizontalStackLayout Grid.Row="1" Margin="16,8" Spacing="12">
                <Label Text="Filtrar:" Style="{StaticResource CaptionText}" VerticalOptions="Center"/>
                <Picker ItemsSource="{Binding FilterOptions}"
                        SelectedItem="{Binding SelectedFilter}"
                        Title="No Resueltas"
                        Style="{StaticResource FormPicker}" WidthRequest="160"/>
            </HorizontalStackLayout>

            <Grid Grid.Row="2">

                <VerticalStackLayout IsVisible="{Binding IsLoading}"
                                     HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource ColorPrimary}"/>
                    <Label Text="Cargando alertas..." Style="{StaticResource BodyText}" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding HasError}"
                                     HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                    <Label Text="⚠" FontSize="40" HorizontalOptions="Center" TextColor="{StaticResource ColorError}"/>
                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource BodyText}" HorizontalOptions="Center"/>
                    <Button Text="Reintentar" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <CollectionView ItemsSource="{Binding Alerts}" IsVisible="{Binding IsSuccess}" Margin="8,0,8,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" Margin="4,4" BackgroundColor="{StaticResource ColorSurface}"
                                    StrokeShape="RoundRectangle 10" Stroke="{StaticResource ColorBorderLight}" StrokeThickness="1">
                                <VerticalStackLayout Spacing="6">
                                    <HorizontalStackLayout Spacing="8">
                                        <Border StrokeShape="RoundRectangle 4" StrokeThickness="0" Padding="5,2"
                                                BackgroundColor="{Binding LevelColor}" VerticalOptions="Center">
                                            <Label Text="{Binding LevelLabel}" FontSize="9" TextColor="White" FontAttributes="Bold"/>
                                        </Border>
                                        <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource ColorTextPrimary}" LineBreakMode="TailTruncation"/>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Message}" Style="{StaticResource CaptionText}" LineBreakMode="WordWrap" MaxLines="3"/>
                                    <Label Text="{Binding CreatedAtFormatted}" FontSize="11" TextColor="{StaticResource Gray500}"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0" Text="✓ Marcar leída" FontSize="12" HeightRequest="30" Padding="4,0"
                                                BackgroundColor="{StaticResource ColorSuccess}" TextColor="White" CornerRadius="6"
                                                HorizontalOptions="Fill"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkReadCommand}"
                                                CommandParameter="{Binding .}"/>
                                        <Button Grid.Column="1" Text="Resuelta" FontSize="12" HeightRequest="30" Padding="4,0"
                                                BackgroundColor="{StaticResource ColorInfo}" TextColor="White" CornerRadius="6"
                                                HorizontalOptions="Fill"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkResolvedCommand}"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Padding="20">
                            <Label Text="🔔" FontSize="48" HorizontalOptions="Center"/>
                            <Label Text="No hay alertas pendientes" Style="{StaticResource BodyText}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

            </Grid>

            <Border Grid.Row="3" BackgroundColor="#1A1A2E" StrokeThickness="0" Padding="16,10">
                <Button Text="🔍 Verificar alertas ahora" Command="{Binding CheckAlertsCommand}"
                        BackgroundColor="#1565C0" TextColor="White" FontAttributes="Bold"
                        HeightRequest="46" CornerRadius="10" HorizontalOptions="Fill"/>
            </Border>
        </Grid>
    </RefreshView>
</ContentPage>

<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Dashboard"
    x:Class="MaintManager.MAUI.Views.Dashboard.HomePage"
    x:DataType="vm:HomeViewModel"
    Title="Panel Principal"
    BackgroundColor="{StaticResource ColorBackground}">

    <Grid>
        <!-- LOADING -->
        <VerticalStackLayout IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
            <ActivityIndicator IsRunning="True"
                               Color="{StaticResource ColorPrimary}"/>
            <Label Text="Cargando panel principal..."
                   Style="{StaticResource BodyText}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- ERROR -->
        <VerticalStackLayout IsVisible="{Binding HasError}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
            <Label Text="⚠" FontSize="40" HorizontalOptions="Center"
                   TextColor="{StaticResource ColorError}"/>
            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource BodyText}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            <Button Text="Reintentar"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- EMPTY -->
        <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
            <Label Text="📋" FontSize="48" HorizontalOptions="Center"/>
            <Label Text="No hay datos disponibles."
                   Style="{StaticResource BodyText}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- SUCCESS -->
        <ScrollView IsVisible="{Binding IsSuccess}">
            <VerticalStackLayout Spacing="16" Padding="16,8">

                <!-- Page Title -->
                <Label Text="Panel Principal"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"
                       Margin="0,8,0,0"/>

                <!-- KPI Cards Row (2 columns) -->
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="12" RowSpacing="12">
                    <Border Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource Card}"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding KpiItems[0].Icon}"
                                   FontSize="28"/>
                            <Label Text="{Binding KpiItems[0].Value}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorPrimary}"/>
                            <Label Text="{Binding KpiItems[0].Label}"
                                   Style="{StaticResource CaptionText}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource Card}"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding KpiItems[1].Icon}"
                                   FontSize="28"/>
                            <Label Text="{Binding KpiItems[1].Value}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorWarning}"/>
                            <Label Text="{Binding KpiItems[1].Label}"
                                   Style="{StaticResource CaptionText}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource Card}"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding KpiItems[2].Icon}"
                                   FontSize="28"/>
                            <Label Text="{Binding KpiItems[2].Value}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorError}"/>
                            <Label Text="{Binding KpiItems[2].Label}"
                                   Style="{StaticResource CaptionText}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource Card}"
                            Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding KpiItems[3].Icon}"
                                   FontSize="28"/>
                            <Label Text="{Binding KpiItems[3].Value}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorInfo}"/>
                            <Label Text="{Binding KpiItems[3].Label}"
                                   Style="{StaticResource CaptionText}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Fleet Section -->
                <Label Text="Flota"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"
                       Margin="0,4,0,0"/>

                <CollectionView ItemsSource="{Binding Vehicles}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:HomeViewModel+VehicleCard">
                            <Border Padding="14" Margin="0,0,0,8"
                                    BackgroundColor="{StaticResource ColorSurface}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource ColorBorderLight}"
                                    StrokeThickness="1">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding LicensePlate}"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource ColorTextPrimary}"/>
                                    <Border Grid.Row="0" Grid.Column="1"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 99"
                                            Padding="8,2"
                                            BackgroundColor="{StaticResource ColorInfoContainer}">
                                        <Label Text="{Binding Status}"
                                               FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource ColorInfo}"/>
                                    </Border>
                                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding Brand, StringFormat='{0} {1}'}"
                                           Style="{StaticResource CaptionText}"
                                           Margin="0,2,0,0"/>
                                    <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2"
                                                           Spacing="16" Margin="0,6,0,0">
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="Kilometraje"
                                                   Style="{StaticResource CaptionText}"/>
                                            <Label Text="{Binding KmProgress}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource ColorTextSecondary}"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="Próximo Service"
                                                   Style="{StaticResource CaptionText}"/>
                                            <Label Text="{Binding KmUntilService, StringFormat='{0:N0} km'}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="{StaticResource ColorPrimary}"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Quick Actions -->
                <Label Text="Acciones Rápidas"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"
                       Margin="0,4,0,0"/>

                <Grid ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="🚗&#x0a;Nuevo&#x0a;Mantenimiento"
                            Command="{Binding NavigateToMaintenanceCommand}"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" HeightRequest="80" Padding="4"/>
                    <Button Grid.Column="1"
                            Text="📅&#x0a;Calendario"
                            Command="{Binding NavigateToCalendarCommand}"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" HeightRequest="80" Padding="4"/>
                    <Button Grid.Column="2"
                            Text="📦&#x0a;Inventario"
                            Command="{Binding NavigateToInventoryCommand}"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" HeightRequest="80" Padding="4"/>
                    <Button Grid.Column="3"
                            Text="📊&#x0a;BI&#x0a;Dashboard"
                            Command="{Binding NavigateToBiDashboardCommand}"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" HeightRequest="80" Padding="4"/>
                </Grid>

                <!-- Maintenance Status Summary -->
                <Label Text="Resumen de Mantenimientos"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"
                       Margin="0,4,0,0"/>

                <Border Padding="14"
                        BackgroundColor="{StaticResource ColorSurface}"
                        StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnDefinitions="*,*"
                          RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Programados"
                               Style="{StaticResource CaptionText}"/>
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="0"
                               FontAttributes="Bold"
                               TextColor="{StaticResource ColorInfo}"
                               HorizontalTextAlignment="End"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="En Progreso"
                               Style="{StaticResource CaptionText}"/>
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="0"
                               FontAttributes="Bold"
                               TextColor="{StaticResource ColorWarning}"
                               HorizontalTextAlignment="End"/>
                        <Label Grid.Row="2" Grid.Column="0"
                               Text="Completados (este mes)"
                               Style="{StaticResource CaptionText}"/>
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="0"
                               FontAttributes="Bold"
                               TextColor="{StaticResource ColorSuccess}"
                               HorizontalTextAlignment="End"/>
                        <Label Grid.Row="3" Grid.Column="0"
                               Text="Emergencia"
                               Style="{StaticResource CaptionText}"/>
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="0"
                               FontAttributes="Bold"
                               TextColor="{StaticResource ColorError}"
                               HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Bottom spacing -->
                <BoxView HeightRequest="24" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

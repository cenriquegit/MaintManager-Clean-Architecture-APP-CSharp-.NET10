<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Dashboard"
    x:Class="MaintManager.MAUI.Views.Dashboard.HomePage"
    Title="Panel Principal"
    BackgroundColor="{StaticResource ColorBackground}">

    <Grid>
        <!-- LOADING -->
        <VerticalStackLayout IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
            <ActivityIndicator IsRunning="True"
                               Color="{StaticResource ColorPrimary}"/>
            <Label Text="Cargando panel principal..."
                   Style="{StaticResource BodyText}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- ERROR -->
        <VerticalStackLayout IsVisible="{Binding HasError}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
            <Label Text="⚠" FontSize="40" HorizontalOptions="Center"
                   TextColor="{StaticResource ColorError}"/>
            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource BodyText}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            <Button Text="Reintentar"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- EMPTY -->
        <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                             HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
            <Label Text="📋" FontSize="48" HorizontalOptions="Center"/>
            <Label Text="No hay datos disponibles."
                   Style="{StaticResource BodyText}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- SUCCESS -->
        <ScrollView IsVisible="{Binding IsSuccess}">
            <VerticalStackLayout Spacing="16" Padding="16,8,16,24">

                <!-- Page Title -->
                <Label Text="Panel Principal"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"
                       Margin="0,8,0,0"/>

                <!-- KPI Cards Row (2 columns) - Compact -->
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="12" RowSpacing="12">
                    <Border Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource Card}"
                            Padding="12,10">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding KpiItems[0].Value}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorPrimary}"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding KpiItems[0].Icon}"
                                       FontSize="22" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding KpiItems[0].Label}"
                                   Style="{StaticResource CaptionText}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource Card}"
                            Padding="12,10">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding KpiItems[1].Value}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorPrimary}"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding KpiItems[1].Icon}"
                                       FontSize="22" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding KpiItems[1].Label}"
                                   Style="{StaticResource CaptionText}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource Card}"
                            Padding="12,10">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding KpiItems[2].Value}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorError}"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding KpiItems[2].Icon}"
                                       FontSize="22" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding KpiItems[2].Label}"
                                   Style="{StaticResource CaptionText}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1"
                            Style="{StaticResource Card}"
                            Padding="12,10">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding KpiItems[3].Value}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="{StaticResource ColorInfo}"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding KpiItems[3].Icon}"
                                       FontSize="22" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding KpiItems[3].Label}"
                                   Style="{StaticResource CaptionText}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Fleet Section -->
                <Label Text="Flota"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"
                       Margin="0,4,0,0"/>

                <CollectionView ItemsSource="{Binding Vehicles}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" Margin="0,0,0,8"
                                    BackgroundColor="{StaticResource ColorSurface}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="{StaticResource ColorBorderLight}"
                                    StrokeThickness="1">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding LicensePlate}"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource ColorTextPrimary}"/>
                                    <Border Grid.Row="0" Grid.Column="1"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 99"
                                            Padding="8,2"
                                            BackgroundColor="{StaticResource ColorInfoContainer}">
                                        <Label Text="{Binding Status}"
                                               FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource ColorInfo}"/>
                                    </Border>
                                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding VehicleName}"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="{StaticResource ColorTextPrimary}"
                                           Margin="0,2,0,0"/>
                                    <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2"
                                                           Spacing="16" Margin="0,6,0,0">
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="Kilometraje"
                                                   Style="{StaticResource CaptionText}"/>
                                            <Label Text="{Binding KmProgress}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource ColorTextSecondary}"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Spacing="0">
                                            <Label Text="Próximo Service"
                                                   Style="{StaticResource CaptionText}"/>
                                            <Label Text="{Binding KmUntilService, StringFormat='{0:N0} km'}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="{StaticResource ColorPrimary}"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Quick Actions -->
                <Label Text="Acciones Rápidas"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"
                       Margin="0,4,0,0"/>

                <Grid ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="6">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource ColorPrimary}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToMaintenanceCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="1" Padding="4,10">
                            <Label Text="🚗" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="Nuevo" FontSize="11" TextColor="White" HorizontalOptions="Center"/>
                            <Label Text="Mantenimiento" FontSize="11" TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource ColorInfo}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCalendarCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="1" Padding="4,16">
                            <Label Text="📅" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="Calendario" FontSize="11" TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource ColorWarning}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToInventoryCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="1" Padding="4,16">
                            <Label Text="📦" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="Inventario" FontSize="11" TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="3"
                            BackgroundColor="{StaticResource ColorAccentDark}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToBiDashboardCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="1" Padding="4,10">
                            <Label Text="📊" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="BI" FontSize="11" TextColor="White" HorizontalOptions="Center"/>
                            <Label Text="Dashboard" FontSize="11" TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Maintenance Status Summary -->
                <Label Text="Resumen de Mantenimientos"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"
                       Margin="0,4,0,0"/>

                <Border Padding="14"
                        BackgroundColor="{StaticResource ColorSurface}"
                        StrokeShape="RoundRectangle 10"
                        Stroke="{StaticResource ColorBorderLight}"
                        StrokeThickness="1">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnDefinitions="*,*"
                          RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0"
                                Text="Programados"
                                Style="{StaticResource CaptionText}"/>
                        <Label Grid.Row="0" Grid.Column="1"
                                Text="{Binding ScheduledCount}"
                                FontAttributes="Bold"
                                TextColor="{StaticResource ColorInfo}"
                                HorizontalTextAlignment="End"/>
                        <Label Grid.Row="1" Grid.Column="0"
                                Text="En Progreso"
                                Style="{StaticResource CaptionText}"/>
                        <Label Grid.Row="1" Grid.Column="1"
                                Text="{Binding InProgressCount}"
                                FontAttributes="Bold"
                                TextColor="{StaticResource ColorWarning}"
                                HorizontalTextAlignment="End"/>
                        <Label Grid.Row="2" Grid.Column="0"
                                Text="Completados (este mes)"
                                Style="{StaticResource CaptionText}"/>
                        <Label Grid.Row="2" Grid.Column="1"
                                Text="{Binding CompletedThisMonth}"
                                FontAttributes="Bold"
                                TextColor="{StaticResource ColorSuccess}"
                                HorizontalTextAlignment="End"/>
                        <Label Grid.Row="3" Grid.Column="0"
                                Text="Emergencia"
                                Style="{StaticResource CaptionText}"/>
                        <Label Grid.Row="3" Grid.Column="1"
                                Text="{Binding EmergencyThisMonth}"
                                FontAttributes="Bold"
                                TextColor="{StaticResource ColorError}"
                                HorizontalTextAlignment="End"/>
                    </Grid>
                </Border>

                <!-- Bottom spacing -->
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

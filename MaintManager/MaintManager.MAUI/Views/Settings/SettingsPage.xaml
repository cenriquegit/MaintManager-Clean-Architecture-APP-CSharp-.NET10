<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Settings"
    x:Class="MaintManager.MAUI.Views.Settings.SettingsPage"
    x:DataType="vm:SettingsViewModel"
    Title="Configuración del Sistema"
    BackgroundColor="{StaticResource ColorBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20,20,20,44">

            <!-- Sección: Parámetros del Sistema (principal) -->
            <Border Style="{StaticResource Card}"
                    IsVisible="{Binding ConfigLoaded}">
                <VerticalStackLayout Spacing="12" Padding="16">

                    <Label Text="Parámetros del Sistema"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource ColorTextPrimary}"/>

                    <Label Text="Configuración general de mantenimientos"
                           Style="{StaticResource BodyText}"/>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource ColorBorderLight}"/>

                    <Label Text="Intervalo entre mantenimientos (km)"
                           Style="{StaticResource CaptionText}"/>
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource ColorBorder}"
                            StrokeThickness="1" Padding="12,0">
                        <Entry Text="{Binding IntervalKm}"
                               Keyboard="Numeric"
                               TextColor="{StaticResource ColorTextPrimary}"/>
                    </Border>

                    <Label Text="Umbral de alerta de km próximo"
                           Style="{StaticResource CaptionText}"/>
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource ColorBorder}"
                            StrokeThickness="1" Padding="12,0">
                        <Entry Text="{Binding AlertKmThreshold}"
                               Keyboard="Numeric"
                               TextColor="{StaticResource ColorTextPrimary}"/>
                    </Border>

                    <Button Text="Guardar parámetros"
                            Command="{Binding SaveConfigCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalOptions="Fill"/>
                </VerticalStackLayout>
            </Border>

            <!-- Loading while config is loading -->
            <VerticalStackLayout IsVisible="{Binding ConfigLoaded, Converter={StaticResource InvertedBoolConverter}}"
                                 HorizontalOptions="Center" VerticalOptions="Center" Spacing="12"
                                 Padding="0,40,0,0">
                <ActivityIndicator IsRunning="True" Color="{StaticResource ColorPrimary}"/>
                <Label Text="Cargando configuración..."
                       Style="{StaticResource BodyText}" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Sección: Cerrar sesión -->
            <Button Text="Cerrar sesión"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="{StaticResource ColorError}"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="12"
                    Margin="0,8,0,0"
                    HorizontalOptions="Fill"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

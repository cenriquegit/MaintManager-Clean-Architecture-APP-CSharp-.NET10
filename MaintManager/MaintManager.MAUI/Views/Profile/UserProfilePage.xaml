<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MaintManager.MAUI.ViewModels.Profile"
    x:Class="MaintManager.MAUI.Views.Profile.UserProfilePage"
    x:DataType="vm:UserProfileViewModel"
    Title="Mi Perfil"
    BackgroundColor="{StaticResource ColorBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20,20,20,44">

            <!-- Información del usuario -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12" Padding="16" HorizontalOptions="Center">

                    <Border StrokeShape="RoundRectangle 40"
                            BackgroundColor="{StaticResource ColorPrimary}"
                            WidthRequest="72" HeightRequest="72"
                            HorizontalOptions="Center"
                            StrokeThickness="0">
                        <Label Text="👤" FontSize="32"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <Label Text="{Binding UserName}"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource ColorTextPrimary}"
                           HorizontalOptions="Center"/>

                    <Label Text="{Binding UserRole}"
                           FontSize="14"
                           TextColor="{StaticResource ColorTextSecondary}"
                           HorizontalOptions="Center"/>

                    <Label Text="{Binding UserUsername, StringFormat='@{0}'}"
                           FontSize="13"
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Botón Cerrar sesión -->
            <Button Text="Cerrar sesión"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="{StaticResource ColorError}"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="12"
                    HorizontalOptions="Fill"/>

            <!-- Sección Admin: Crear usuario -->
            <VerticalStackLayout IsVisible="{Binding IsAdmin}" Spacing="16">

                <BoxView HeightRequest="1"
                         BackgroundColor="{StaticResource ColorBorderLight}"/>

                <Label Text="Administración"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"/>

                <Label Text="Crear nuevo usuario"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource ColorTextPrimary}"/>

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12" Padding="16">

                        <Label Text="Nombre de usuario"
                               Style="{StaticResource CaptionText}"/>
                        <Entry Text="{Binding NewUsername}"
                               Placeholder="ej: juan.perez"
                               TextColor="{StaticResource ColorTextPrimary}"
                               PlaceholderColor="{StaticResource Gray500}"/>

                        <Label Text="Contraseña"
                               Style="{StaticResource CaptionText}"/>
                        <Entry Text="{Binding NewPassword}"
                               IsPassword="True"
                               Placeholder="Contraseña"
                               TextColor="{StaticResource ColorTextPrimary}"
                               PlaceholderColor="{StaticResource Gray500}"/>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Label Text="Datos personales"
                               Style="{StaticResource BodyText}"
                               FontAttributes="Bold"/>

                        <Label Text="Nombres" Style="{StaticResource CaptionText}"/>
                        <Entry Text="{Binding NewName}"
                               Placeholder="ej: Juan Carlos"
                               TextColor="{StaticResource ColorTextPrimary}"
                               PlaceholderColor="{StaticResource Gray500}"/>

                        <Label Text="Apellido paterno" Style="{StaticResource CaptionText}"/>
                        <Entry Text="{Binding NewFln}"
                               Placeholder="ej: Pérez"
                               TextColor="{StaticResource ColorTextPrimary}"
                               PlaceholderColor="{StaticResource Gray500}"/>

                        <Label Text="Apellido materno" Style="{StaticResource CaptionText}"/>
                        <Entry Text="{Binding NewMln}"
                               Placeholder="ej: López"
                               TextColor="{StaticResource ColorTextPrimary}"
                               PlaceholderColor="{StaticResource Gray500}"/>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{StaticResource ColorBorderLight}"/>

                        <Label Text="Email" Style="{StaticResource CaptionText}"/>
                        <Entry Text="{Binding NewEmail}"
                               Placeholder="ej: juan@correo.com"
                               Keyboard="Email"
                               TextColor="{StaticResource ColorTextPrimary}"
                               PlaceholderColor="{StaticResource Gray500}"/>

                        <Label Text="Rol" Style="{StaticResource CaptionText}"/>
                        <Picker ItemsSource="{Binding RoleOptions}"
                                SelectedItem="{Binding NewRole}"
                                Style="{StaticResource FormPicker}"/>

                        <Button Text="Crear usuario"
                                Command="{Binding CreateUserCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalOptions="Fill"/>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="UTF-8" ?>
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:MaintManager.MAUI.Converters"
    x:Class="MaintManager.MAUI.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════ COLORES BASE ENTERPRISE ═══════════ -->
            <Color x:Key="ColorPrimary">#1565C0</Color>
            <Color x:Key="ColorSecondary">#0D47A1</Color>
            <Color x:Key="ColorPrimaryDark">#0D47A1</Color>
            <Color x:Key="ColorInfo">#1976D2</Color>
            <Color x:Key="ColorInfoContainer">#E3F2FD</Color>
            <Color x:Key="ColorSuccess">#2E7D32</Color>
            <Color x:Key="ColorSuccessContainer">#E8F5E9</Color>
            <Color x:Key="ColorWarning">#F57C00</Color>
            <Color x:Key="ColorWarningContainer">#FFF3E0</Color>
            <Color x:Key="ColorError">#C62828</Color>
            <Color x:Key="ColorErrorContainer">#FFEBEE</Color>
            <Color x:Key="ColorBorder">#BDBDBD</Color>
            <Color x:Key="ColorSurface">#FFFFFF</Color>
            <Color x:Key="ColorTextPrimary">#212121</Color>
            <Color x:Key="ColorAccentDark">#F57C00</Color>
            <Color x:Key="ColorTextSecondary">#546E8A</Color>
            <Color x:Key="ColorBackground">#F5F5F5</Color>
            <Color x:Key="ColorBorderLight">#E0E0E0</Color>
            <Color x:Key="ColorSurfaceVariant">#F0F0F0</Color>

            <!-- ═══════════ CONVERTERS ═══════════ -->
            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <conv:IsNotNullConverter x:Key="IsNotNullConverter"/>
            <conv:IsNullConverter x:Key="IsNullConverter"/>
            <conv:IntToBoolConverter x:Key="IntToBoolConverter"/>
            <conv:StringEqualsConverter x:Key="StringEqualsConverter"/>
            <conv:AlertTypeToColorConverter x:Key="AlertTypeToColorConverter"/>
            <conv:AlertTypeToLabelConverter x:Key="AlertTypeToLabelConverter"/>
            <conv:StockStatusColorConverter x:Key="StockStatusColorConverter"/>
            <conv:DaysUntilExpiryColorConverter x:Key="DaysUntilExpiryColorConverter"/>
            <conv:BoolToColorConverter x:Key="BelowMinimumColorConverter"
                                       TrueColor="#C62828"
                                       FalseColor="#2E7D32"/>

            <!-- ═══════════ ESTILOS GLOBALES (sobrescriben Styles.xaml) ═══════════ -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
            </Style>
            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource Gray500}" />
            </Style>
            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource Gray500}" />
            </Style>

            <!-- ═══════════ ESTILOS ESENCIALES ═══════════ -->
            <Style x:Key="BodyText" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
            </Style>
            <Style x:Key="CaptionText" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextColor" Value="#757575" />
            </Style>
            <Style x:Key="FormEntry" TargetType="Entry">
                <Setter Property="FontSize" Value="16" />
            </Style>
            <Style x:Key="FormPicker" TargetType="Picker">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="TitleColor" Value="{StaticResource Gray500}" />
            </Style>
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorPrimary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#EEEEEE" />
                <Setter Property="TextColor" Value="#333333" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
            <Style x:Key="TitleMedium" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
            </Style>
            <Style x:Key="AccentButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorAccentDark}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,8" />
            </Style>

            <!-- ═══════════ ESTILOS DE TARJETA ═══════════ -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorSurface}" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Stroke" Value="{StaticResource ColorBorderLight}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="0,4" />
            </Style>

            <Style x:Key="BadgeError" TargetType="Border">
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 99" />
                <Setter Property="Padding" Value="8,3" />
                <Setter Property="BackgroundColor" Value="{StaticResource ColorErrorContainer}" />
            </Style>

            <Style x:Key="BadgeSuccess" TargetType="Border">
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 99" />
                <Setter Property="Padding" Value="8,3" />
                <Setter Property="BackgroundColor" Value="{StaticResource ColorSuccessContainer}" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
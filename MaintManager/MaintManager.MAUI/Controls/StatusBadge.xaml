<?xml version="1.0" encoding="utf-8"?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MaintManager.MAUI.Controls.StatusBadge"
    x:Name="BadgeRoot">

    <Border x:Name="BadgeBorder"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 99"
            Padding="10,4"
            BackgroundColor="{Binding Source={x:Reference BadgeRoot}, Path=Color}">
        <Label x:Name="BadgeLabel"
               Text="{Binding Source={x:Reference BadgeRoot}, Path=Text}"
               TextColor="White"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>
    </Border>

</ContentView>

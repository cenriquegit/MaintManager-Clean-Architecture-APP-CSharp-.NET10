<?xml version="1.0" encoding="utf-8"?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MaintManager.MAUI.Controls.VehicleCard"
    x:Name="VehicleRoot">

    <Border Padding="16"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 12"
            BackgroundColor="White">
        <Border.Shadow>
            <Shadow Brush="#33000000" Offset="0,2" Radius="4" Opacity="0.15"/>
        </Border.Shadow>
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" RowSpacing="6" ColumnSpacing="12">
            <BoxView Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                     x:Name="StatusDot"
                     WidthRequest="10" HeightRequest="10"
                     CornerRadius="5"
                     VerticalOptions="Center"/>

            <Label Grid.Row="0" Grid.Column="1"
                   Text="{Binding Source={x:Reference VehicleRoot}, Path=LicensePlate}"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#212121"/>

            <Label Grid.Row="1" Grid.Column="1"
                   Text="{Binding Source={x:Reference VehicleRoot}, Path=VehicleName}"
                   FontSize="13"
                   TextColor="#546E8A"/>

            <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                    Text="Iniciar"
                    FontSize="12"
                    BackgroundColor="{StaticResource ColorPrimary}"
                    TextColor="White"
                    CornerRadius="6"
                    Padding="10,4"
                    VerticalOptions="Center"
                    Command="{Binding Source={x:Reference VehicleRoot}, Path=OnStartMaintenanceCommand}"
                    CommandParameter="{Binding Source={x:Reference VehicleRoot}, Path=LicensePlate}"/>

            <BoxView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                     HeightRequest="1"
                     Color="#E0E0E0"
                     Margin="0,2,0,0"/>

            <HorizontalStackLayout Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Spacing="24" Margin="0,4,0,0">
                <VerticalStackLayout Spacing="2">
                    <Label Text="KM Actual"
                           FontSize="11"
                           TextColor="#757575"/>
                    <Label Text="{Binding Source={x:Reference VehicleRoot}, Path=CurrentKm}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#212121"/>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="2">
                    <Label Text="Próximo Servicio"
                           FontSize="11"
                           TextColor="#757575"/>
                    <Label Text="{Binding Source={x:Reference VehicleRoot}, Path=NextMaintenanceKm}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#212121"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Grid>
    </Border>

</ContentView>
